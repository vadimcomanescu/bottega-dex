#!/usr/bin/env node

import {
  readFileSync,
  writeFileSync,
} from "node:fs";
import { resolve } from "node:path";
import {
  assertIsolatedGitWorktree,
  assertTrackedWorktreeClean,
  assertTrackedWorktreeUnchanged,
  binaryOnPath,
  fail,
  parseClaudeArgs,
  readTrackedWorktreeIdentity,
  spawnBounded,
  usesRequestedClaudeModel,
} from "./exec-common.js";

const ROUTES = {
  reviewer: {
    model: "opus",
    effort: "xhigh",
    permission: "dontAsk",
    tools: "Bash,Read,Glob,Grep",
    requiresIsolatedWorktree: true,
    timeoutMs: 1_200_000,
  },
  panelist: {
    model: "opus",
    effort: "xhigh",
    permission: "dontAsk",
    tools: "Bash,Read,Glob,Grep",
    requiresIsolatedWorktree: false,
    timeoutMs: 900_000,
  },
  judge: {
    model: "opus",
    effort: "high",
    permission: "dontAsk",
    tools: "",
    requiresIsolatedWorktree: false,
    timeoutMs: 900_000,
  },
};

const PREFIX = "claude-exec";
const values = parseClaudeArgs(PREFIX);
if (resolve(values.out) === resolve(values.events)) {
  fail(PREFIX, "--out and --events must be distinct paths");
}

const route = ROUTES[values.role];
if (!route) fail(PREFIX, `unknown role '${values.role}'`);
const requestedFrozenTarget = route.requiresIsolatedWorktree
  ? { headSha: values.head, treeSha: values.tree }
  : null;
if (route.requiresIsolatedWorktree) {
  for (const name of ["head", "tree"]) {
    if (!values[name]) fail(PREFIX, `--${name} is required for reviewer calls`);
  }
}
let frozenTarget = null;
if (route.requiresIsolatedWorktree) {
  assertIsolatedGitWorktree(PREFIX, values.cwd, {
    allowMissing: values["dry-run"],
  });
  if (!values["dry-run"]) {
    assertTrackedWorktreeClean(PREFIX, values.cwd);
    frozenTarget = readTrackedWorktreeIdentity(PREFIX, values.cwd);
    if (
      frozenTarget.headSha !== requestedFrozenTarget.headSha
      || frozenTarget.treeSha !== requestedFrozenTarget.treeSha
    ) {
      fail(
        PREFIX,
        `review checkout does not match the frozen target: expected ${requestedFrozenTarget.headSha}/${requestedFrozenTarget.treeSha}, got ${frozenTarget.headSha}/${frozenTarget.treeSha}`,
      );
    }
  }
}

let schema;
try {
  schema = readFileSync(values.schema, "utf8");
} catch (error) {
  fail(PREFIX, `cannot read schema: ${error.message}`);
}

const argv = [
  "-p",
  "--safe-mode",
  "--model", route.model,
  "--effort", route.effort,
  "--permission-mode", route.permission,
  "--tools", route.tools,
  "--output-format", "json",
];
argv.push("--no-session-persistence");
argv.push("--json-schema", schema);

if (values["dry-run"]) {
  process.stdout.write(`${JSON.stringify({
    command: "claude",
    argv,
    stdin: values.brief,
    stdout: values.events,
    cwd: values.cwd,
    schemaFile: values.schema ?? null,
    route,
    frozenTarget: requestedFrozenTarget,
  })}\n`);
  process.exit(0);
}

// An empty brief would still produce a schema-shaped report, so it is a
// dispatch error, never a reviewable input.
let brief;
try {
  brief = readFileSync(values.brief, "utf8");
} catch (error) {
  fail(PREFIX, `cannot read brief: ${error.message}`);
}
if (!brief.trim()) fail(PREFIX, "brief is empty");

const command = binaryOnPath("claude");
if (!command) {
  process.stderr.write("claude-exec: claude was not found in an absolute PATH entry\n");
  process.exit(127);
}

const versionResult = spawnBounded(command, ["--version"], {
  encoding: "utf8",
}, 10_000);
if (versionResult.status !== 0 || !versionResult.stdout?.trim()) {
  process.stderr.write("claude-exec: could not record the Claude CLI version\n");
  process.exit(1);
}
const cliVersion = versionResult.stdout.trim();

const result = spawnBounded(command, argv, {
  cwd: values.cwd,
  input: brief,
  encoding: "utf8",
  maxBuffer: 64 * 1024 * 1024,
}, route.timeoutMs);
writeFileSync(values.events, result.stdout ?? "");
if (result.stderr) process.stderr.write(result.stderr);
if (result.error) {
  if (result.error.code === "ETIMEDOUT") {
    process.stderr.write(
      `claude-exec: ${values.role} exceeded its ${route.timeoutMs}ms timeout\n`,
    );
    process.exit(124);
  }
  process.stderr.write(`claude-exec: ${result.error.message}\n`);
  process.exit(1);
}
if (result.status !== 0) process.exit(result.status ?? 1);

let envelope;
try {
  envelope = JSON.parse(result.stdout);
} catch {
  process.stderr.write("claude-exec: Claude did not return a JSON result envelope\n");
  process.exit(1);
}

if (envelope.is_error === true || envelope.subtype !== "success") {
  process.stderr.write("claude-exec: Claude returned a non-success result envelope\n");
  process.exit(1);
}
if (!usesRequestedClaudeModel(envelope, route.model)) {
  process.stderr.write(
    `claude-exec: result did not prove usage of requested model '${route.model}'\n`,
  );
  process.exit(1);
}
if (route.requiresIsolatedWorktree) {
  assertTrackedWorktreeUnchanged(PREFIX, values.cwd, frozenTarget);
}

const answer = envelope.structured_output;
if (answer === undefined || answer === null) {
  process.stderr.write("claude-exec: Claude result envelope contained no answer\n");
  process.exit(1);
}
writeFileSync(values.events, `${JSON.stringify({
  schema_version: 1,
  provider: "claude",
  cli_version: cliVersion,
  requested_role: values.role,
  requested_route: route,
  frozen_target: frozenTarget,
  process: { status: result.status, signal: result.signal },
  envelope,
}, null, 2)}\n`);
writeFileSync(
  values.out,
  typeof answer === "string" ? answer : `${JSON.stringify(answer, null, 2)}\n`,
);
if (route.requiresIsolatedWorktree) {
  assertTrackedWorktreeUnchanged(PREFIX, values.cwd, frozenTarget);
}
process.exit(0);

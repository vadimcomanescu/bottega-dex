#!/usr/bin/env node

import { spawn } from "node:child_process";
import {
  mkdirSync,
  readFileSync,
  writeFileSync,
} from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { parseArgs } from "node:util";

const SCRIPTS_DIR = dirname(fileURLToPath(import.meta.url));
const PLUGIN_ROOT = join(SCRIPTS_DIR, "..");
const WORKER = join(SCRIPTS_DIR, "worker-exec");
const PANELIST_SCHEMA = join(
  PLUGIN_ROOT,
  "skills",
  "panel",
  "references",
  "panelist.schema.json",
);
const JUDGE_SCHEMA = join(
  PLUGIN_ROOT,
  "skills",
  "panel",
  "references",
  "judge.schema.json",
);

function fail(message) {
  process.stderr.write(`panel-run: ${message}\n`);
  process.exit(2);
}

let values;
try {
  ({ values } = parseArgs({
    options: {
      cwd: { type: "string" },
      task: { type: "string" },
      dir: { type: "string" },
      out: { type: "string" },
      "dry-run": { type: "boolean", default: false },
    },
  }));
} catch (error) {
  fail(error.message);
}

for (const name of ["cwd", "task", "dir", "out"]) {
  if (!values[name]) fail(`--${name} is required`);
}

const plan = {
  draftRoles: ["codex-panelist", "claude-panelist"],
  judgeRole: "claude-judge",
  panelistSchema: PANELIST_SCHEMA,
  judgeSchema: JUDGE_SCHEMA,
  blinding: "Judge input contains Task, Draft A, and Draft B only.",
};
if (values["dry-run"]) {
  process.stdout.write(`${JSON.stringify(plan)}\n`);
  process.exit(0);
}

mkdirSync(values.dir, { recursive: true });
const task = readFileSync(values.task, "utf8");
const sharedBrief = join(values.dir, "panel-task.md");
writeFileSync(sharedBrief, task);

function dispatch(role, brief, out, events, schema) {
  return new Promise((resolve, reject) => {
    const child = spawn(process.execPath, [
      WORKER,
      "--role", role,
      "--cwd", values.cwd,
      "--brief", brief,
      "--out", out,
      "--events", events,
      "--schema", schema,
    ], { stdio: "inherit" });
    child.on("error", reject);
    child.on("close", (code) => {
      if (code === 0) resolve();
      else reject(new Error(`${role} exited ${code}`));
    });
  });
}

const aOut = join(values.dir, "draft-a.json");
const bOut = join(values.dir, "draft-b.json");
try {
  await Promise.all([
    dispatch(
      "codex-panelist",
      sharedBrief,
      aOut,
      join(values.dir, "draft-a.events.jsonl"),
      PANELIST_SCHEMA,
    ),
    dispatch(
      "claude-panelist",
      sharedBrief,
      bOut,
      join(values.dir, "draft-b.events.json"),
      PANELIST_SCHEMA,
    ),
  ]);
} catch (error) {
  process.stderr.write(`panel-run: ${error.message}\n`);
  process.exit(1);
}

const draftA = JSON.parse(readFileSync(aOut, "utf8"));
const draftB = JSON.parse(readFileSync(bOut, "utf8"));
const judgeBrief = join(values.dir, "judge-brief.md");
writeFileSync(
  judgeBrief,
  `Task:\n${task}\n\nDraft A:\n${JSON.stringify(draftA)}\n\nDraft B:\n${JSON.stringify(draftB)}\n\nCompare Draft A and Draft B. Do not answer the task.\n`,
);

const judgeOut = join(values.dir, "judge.json");
try {
  await dispatch(
    "claude-judge",
    judgeBrief,
    judgeOut,
    join(values.dir, "judge.events.json"),
    JUDGE_SCHEMA,
  );
} catch (error) {
  process.stderr.write(`panel-run: ${error.message}\n`);
  process.exit(1);
}

const judge = JSON.parse(readFileSync(judgeOut, "utf8"));
writeFileSync(values.out, `${JSON.stringify({ A: draftA, B: draftB, judge }, null, 2)}\n`);
